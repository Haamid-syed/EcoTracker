{
  "version": 2,
  "rewrites": [
    { 
      "source": "/api/(.*)", 
      "destination": "/api/index.py" 
    },
    { 
      "source": "/((?!api/|logo\\.svg|assets/|favicon\\.ico).*)", 
      "destination": "/index.html" 
    },
    { 
      "source": "/(.*)", 
      "destination": "/$1" 
    }
  ]
}
